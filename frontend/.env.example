# Konfigurasi koneksi frontend Next.js ke GeoNode.
# Disetel juga di docker-compose.yml (service `frontend`). Salin ke
# `.env.local` untuk override saat `next dev` lokal di luar docker.

# Base internal untuk SSR fetch API v2 (server-only, tanpa CORS).
# Di docker: nama service django. Di luar docker: http://localhost
GEONODE_INTERNAL_URL=http://django:8000

# Base publik untuk link & gambar yang dimuat browser.
NEXT_PUBLIC_GEONODE_URL=http://localhost
